{
  "name": "mlearn",
  "version": "2.0.0",
  "description": "A Language-learning app that knows what you know for faster learning by immersion",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:3000 && tsc -p src/electron/tsconfig.json && npm run bundle:preload && cross-env NODE_ENV=development electron .",
    "build:german-dict": "python3 src/root-of-app/languages/de/build_dict.py",
    "clean:dist-electron-cache": "rm -f dist-electron/dictionary_cache.sqlite3 dist-electron/anki-cache.json dist-electron/anki-cache.pkl.bak dist-electron/anki-cache.pkl",
    "clean:release": "rm -rf release",
    "prebuild": "npm run clean:dist-electron-cache && npm run build:german-dict",
    "predist": "npm run clean:release",
    "predist:mac": "npm run clean:release",
    "predist:win": "npm run clean:release",
    "predist:linux": "npm run clean:release",
    "build": "tsc -p src/electron/tsconfig.json && npm run bundle:preload && vite build",
    "bundle:preload": "esbuild dist-electron/electron/preload.js --bundle --platform=node --outfile=dist-electron/electron/preload.js --allow-overwrite --external:electron",
    "build:web": "vite build --mode web",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p src/electron/tsconfig.json --noEmit",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:tar": "node scripts/pack-tar.js",
    "dev:mobile": "vite build --mode capacitor --watch",
    "build:mobile": "vite build --mode capacitor",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "ios": "npm run build:mobile && npx cap sync && npx cap open ios",
    "android": "npm run build:mobile && npx cap sync && npx cap open android",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "build:extension": "tsc -p extension/tsconfig.json && sed -i '' '/^export {};$/d' extension/dist/content-script.js && cp extension/manifest.json extension/dist/manifest.json && mkdir -p extension/dist/popup && cp extension/src/popup/popup.html extension/src/popup/popup.css extension/dist/popup/"
  },
  "keywords": [
    "language-learning",
    "immersion",
    "japanese",
    "chinese",
    "subtitles",
    "flashcards",
    "srs"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@types/adm-zip": "^0.5.7",
    "@types/chrome": "^0.0.309",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild-plugin-solid": "^0.6.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.1",
    "msw": "^2.12.13",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.0",
    "wait-on": "^8.0.2"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@ffmpeg/core": "^0.12.9",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@solidjs/router": "^0.15.4",
    "@types/qrcode": "^1.5.6",
    "@types/simple-peer": "^9.11.9",
    "@types/tar": "^6.1.13",
    "@types/ws": "^8.18.1",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "jsqr": "^1.4.0",
    "marked": "^17.0.2",
    "node-llama-cpp": "^3.15.1",
    "qrcode": "^1.5.4",
    "simple-peer": "^9.11.1",
    "solid-js": "^1.9.4",
    "tar": "^7.5.2",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "net.morisinc.mlearn",
    "productName": "mLearn",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!dist-electron/.DS_Store",
      "!dist-electron/env{,/**}",
      "!dist-electron/py{,/**}",
      "!dist-electron/python.tar.gz",
      "!dist-electron/python_crash.log",
      "!dist-electron/dictionary_cache.sqlite3",
      "!dist-electron/anki-cache.json",
      "!dist-electron/anki-cache.pkl.bak",
      "!dist-electron/anki-cache.pkl",
      "!dist-electron/dictionaries{,/**}",
      "!dist-electron/assets{,/**}",
      "!dist-electron/languages{,/**}",
      "!dist-electron/locales{,/**}",
      "!dist-electron/server.py",
      "!dist-electron/pip_requirements.json",
      "!dist-electron/version-info.json",
      "!node_modules/@capacitor{,/**}",
      "!node_modules/@ffmpeg{,/**}",
      "!node_modules/solid-js{,/**}",
      "!node_modules/@solidjs{,/**}"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "src/root-of-app/",
        "to": "root-of-app/",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "extension/dist/",
        "to": "extension/dist/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "protocols": [
        {
          "name": "mLearn Auth Callback",
          "schemes": [
            "mlearn"
          ]
        }
      ],
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 140,
          "y": 200
        },
        {
          "x": 660,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "protocols": [
        {
          "name": "mLearn Auth Callback",
          "schemes": [
            "mlearn"
          ]
        }
      ],
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "protocols": [
        {
          "name": "mLearn Auth Callback",
          "schemes": [
            "mlearn"
          ]
        }
      ],
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
