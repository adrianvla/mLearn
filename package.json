{
  "name": "mlearn",
  "version": "2.0.0",
  "description": "Language learning through immersion - SolidJS + TypeScript + Electron",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:3000 && tsc -p src/electron/tsconfig.json && npm run bundle:preload && cross-env NODE_ENV=development electron .",
    "build": "tsc -p src/electron/tsconfig.json && npm run bundle:preload && vite build",
    "bundle:preload": "esbuild dist-electron/electron/preload.js --bundle --platform=node --outfile=dist-electron/electron/preload.js --allow-overwrite --external:electron",
    "build:web": "vite build --mode web",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p src/electron/tsconfig.json --noEmit",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dev:mobile": "vite build --mode capacitor --watch",
    "build:mobile": "vite build --mode capacitor",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "ios": "npm run build:mobile && npx cap sync && npx cap open ios",
    "android": "npm run build:mobile && npx cap sync && npx cap open android",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "language-learning",
    "immersion",
    "japanese",
    "chinese",
    "subtitles",
    "flashcards",
    "srs"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@types/adm-zip": "^0.5.7",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.1",
    "msw": "^2.12.13",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.0",
    "wait-on": "^8.0.2"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@ffmpeg/core": "^0.12.9",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@solidjs/router": "^0.15.4",
    "@types/qrcode": "^1.5.6",
    "@types/simple-peer": "^9.11.9",
    "@types/tar": "^6.1.13",
    "@types/ws": "^8.18.1",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "jsqr": "^1.4.0",
    "marked": "^17.0.2",
    "node-llama-cpp": "^3.15.1",
    "qrcode": "^1.5.4",
    "simple-peer": "^9.11.1",
    "solid-js": "^1.9.4",
    "tar": "^7.5.2",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "net.morisinc.mlearn",
    "productName": "mLearn",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "protocols": [
        {
          "name": "mLearn Auth Callback",
          "schemes": [
            "mlearn"
          ]
        }
      ],
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "protocols": [
        {
          "name": "mLearn Auth Callback",
          "schemes": [
            "mlearn"
          ]
        }
      ],
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "protocols": [
        {
          "name": "mLearn Auth Callback",
          "schemes": [
            "mlearn"
          ]
        }
      ],
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
