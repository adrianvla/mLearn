# mLearn Management Console — Environment Configuration
# Copy to .env and adjust values. NEVER commit a real .env with secrets.

# ===== Compose project name =====
# Must match the project name the mLearn stack was started with.
# Docker Compose stamps every container with com.docker.compose.project=<name>.
MLEARN_COMPOSE_PROJECT=mlearn

# ===== Management console =====
# Port the management web UI listens on inside the container.
MLEARN_MANAGEMENT_PORT=3000

# Bind address. Default 127.0.0.1 (localhost only).
# Set to 0.0.0.0 ONLY if you understand the security implications and have
# a reverse proxy with TLS + authentication in front.
MLEARN_BIND_ADDRESS=127.0.0.1

# Browser-facing origin used in desktop login links. This must be a navigable
# absolute http(s) URL, not 0.0.0.0 or ::. Keep the local default below when
# opening the console on the Docker host. Behind a reverse proxy, set this to
# the external TLS origin, for example https://mlearn.school.edu.
MLEARN_MANAGEMENT_PUBLIC_URL=http://127.0.0.1:3000

# Admin token for API authentication.
# If left empty in production, a random token is generated on first boot
# and its SHA-256 hash is written to the management data volume.
# The plaintext token is logged ONCE to stdout — retrieve with:
#   docker compose logs mlearn-management 2>&1 | grep "Generated admin token"
MLEARN_MANAGEMENT_TOKEN=

# Pre-hashed token (SHA-256 hex). Takes precedence over plaintext token.
# Generate with: echo -n "your-token" | sha256sum | awk '{print $1}'
MLEARN_MANAGEMENT_TOKEN_HASH=

# Path where the auto-generated token hash is persisted.
# In Docker, this should be inside the management data volume.
# If a file exists here with a valid SHA-256 hex hash, it is loaded on startup
# instead of generating a new token.
MLEARN_TOKEN_FILE=/data/admin-token-hash

# ===== Environment mode =====
# "production" enforces fail-closed auth (rejects all requests if no token).
# "development" allows running without auth for local development.
MLEARN_ENV=production

# ===== Deployment info (read-only, surfaced in the UI) =====
# How this stack is deployed: "local-only" | "self-hosted" | "cloud-connected"
MLEARN_DEPLOYMENT_MODE=self-hosted

# mLearn app version (best-effort, surfaced in Overview).
MLEARN_APP_VERSION=

# ===== AI configuration (read-only status, surfaced in AI Status page) =====
# Whether local/offline AI is available in this stack.
MLEARN_LOCAL_AI_ENABLED=true
# Provider name only (e.g. "ollama", "builtin"). No secrets.
MLEARN_LOCAL_AI_PROVIDER=ollama

# Whether cloud LLM access is enabled. Triggers a warning in school mode.
MLEARN_CLOUD_AI_ENABLED=false
# Comma-separated provider names (e.g. "openai,anthropic"). Names only.
MLEARN_CLOUD_AI_PROVIDERS=

# ===== Storage paths (read-only, surfaced in Storage page) =====
MLEARN_LANGUAGE_DATA_PATH=
MLEARN_OCR_DATA_PATH=
MLEARN_MODEL_CACHE_PATH=
MLEARN_APP_DATA_PATH=
MLEARN_DB_PATH=
MLEARN_UPLOADS_PATH=

# ===== Feature flags (read-only) =====
# Comma-separated "name=enabled" pairs, e.g. "voice_clone=false,ocr=true"
MLEARN_FEATURE_FLAGS=
