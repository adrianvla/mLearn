  "conversation": {
    "register": {
      "hasDeferentialForms": true,
      "casualPromptGuidelines": ["Use ты forms and natural conversational Russian unless the learner requests formal speech."],
      "correctionPromptGuidelines": ["Preserve valid ты/вы register choices and correct agreement consistently within the chosen register."]
